# EditorConfig keeps indentation and whitespace identical across every
# contributor's editor. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Trailing spaces are significant in Markdown (hard line breaks).
trim_trailing_whitespace = false

[*.{cmd,bat,ps1}]
# Windows script files must keep CRLF to run correctly everywhere.
end_of_line = crlf

# --- Dependencies ---
node_modules/

# --- Build output ---
dist/
dist-ssr/
*.tsbuildinfo

# --- Environment & credentials (never commit secrets) ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Python virtual environments (in case tooling scripts are added later) ---
.venv/
venv/
__pycache__/

# --- Logs & runtime caches ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.cache/
.eslintcache
.vite/

# --- IDE clutter ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS debris ---
.DS_Store
Thumbs.db
desktop.ini

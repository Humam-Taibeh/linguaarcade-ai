{
  "name": "linguaarcade-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered English learning platform focused on shadowing, ultra-precise pronunciation analysis, and conversational practice.",
  "keywords": [
    "english-learning",
    "shadowing",
    "pronunciation",
    "web-speech-api",
    "gemini",
    "language-learning"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && npm run test && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}

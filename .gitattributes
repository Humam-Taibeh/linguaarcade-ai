# Normalize line endings: source files are stored with LF in the repository
# regardless of the contributor's OS, while Windows-only scripts keep CRLF.
* text=auto eol=lf

*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows scripts require CRLF.
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary assets must never be line-ending normalized.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.mp3   binary
*.wav   binary
